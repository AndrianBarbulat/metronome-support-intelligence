    {
      "id": "contract-409-uniqueness",
      "input_file": "data/examples/contract_409.json",
      "split": "tuning",
      "expected": {
        "product_area": "contracts",
        "http_method": "POST",
        "endpoint_path": "/v1/contracts/create",
        "status_code": 409,
        "primary_source_expected": "Create a contract",
        "expected_sources_by_purpose": {
          "operation": ["Create a contract"],
          "error_behavior": ["API idempotency"],
          "verification": ["Get a contract", "List customer contracts"],
          "configuration": ["rate schedule", "rate card"]
        },
        "discarded_source_forbidden": ["Create a package", "List contracts associated with a package"],
        "required_observation_codes": [
          "request.method.present",
          "request.endpoint.present",
          "response.status.present",
          "request.field.uniqueness_key.present",
          "documentation.behavior.idempotency"
        ],
        "forbidden_observation_codes": ["root_cause.uniqueness_reuse.confirmed"],
        "required_concepts": [
          "contract.determine_retry_intent",
          "contract.locate_previous_operation",
          "contract.inspect_previous_result",
          "contract.retrieve_existing_contract",
          "contract.compare_existing_pricing",
          "contract.decide_key_reuse",
          "contract.prepare_escalation"
        ],
        "forbidden_concepts": [
          "generic.verify_authentication",
          "contract.validate_starting_at",
          "contract.validate_required_fields",
          "contract.reproduce_minimal_valid_payload",
          "generic.capture_complete_request"
        ],
        "allowed_concepts": [
          "contract.determine_retry_intent",
          "contract.locate_previous_operation",
          "contract.inspect_previous_result",
          "contract.retrieve_existing_contract",
          "contract.compare_existing_pricing",
          "contract.decide_key_reuse",
          "contract.prepare_escalation"
        ],
        "required_blocking_concepts": ["contract.locate_previous_operation", "contract.decide_key_reuse"],
        "ordering_constraints": [
          ["contract.locate_previous_operation", "contract.inspect_previous_result"],
          ["contract.retrieve_existing_contract", "contract.compare_existing_pricing"],
          ["contract.compare_existing_pricing", "contract.decide_key_reuse"],
          ["generic.verify_final_state", "contract.prepare_escalation"]
        ],
        "expect_escalation_last": true,
        "expect_redaction": true
      }
    },
