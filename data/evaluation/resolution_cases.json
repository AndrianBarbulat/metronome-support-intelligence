    {
      "id": "contract-uniqueness-conflict",
      "resolution_input_file": "data/examples/resolutions/contract_uniqueness_conflict.json",
      "ticket_input_file": "data/examples/contract_409.json",
      "split": "tuning",
      "forbidden_persisted_terms": ["dozjgNryP4J3jVmNHl0w5N_XgL0n3I9PlFUP0THsR8U"],
      "expected": {
        "expected_root_cause_code": "idempotency.previous_operation_succeeded",
        "expected_hypothesis_outcomes": {
          "contract.409.uniqueness": "partially_confirmed"
        },
        "expected_gap_codes": [
          "docs.missing_troubleshooting",
          "product.no_request_correlation",
          "support.missing_regression_case"
        ],
        "expected_regression_case": true,
        "required_verification_terms": ["API logs", "existing contract", "customer"]
      }
    },
