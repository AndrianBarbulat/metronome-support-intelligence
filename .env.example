# Metronome Support Intelligence — Environment Configuration
# Copy this file to .env and fill in your values.

# Drafting provider configuration
# Use "mock" for development without live API calls
# Use "gemini" for the live demonstration
DRAFTING_PROVIDER=mock

# Gemini API configuration (required when DRAFTING_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Drafting generation settings
DRAFTING_TEMPERATURE=0.2
DRAFTING_MAX_OUTPUT_TOKENS=2048

# Review workflow
DRAFTING_REQUIRE_HUMAN_REVIEW=true
DRAFTING_STORE_FAILED_OUTPUTS=true