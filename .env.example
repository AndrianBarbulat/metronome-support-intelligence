# Metronome Support Intelligence — Environment Configuration
# Copy this file to .env and fill in your values.
# For Vercel deployment, add these in Project Settings → Environment Variables.

# ----- Database -----
# Local development: uses SQLite at data/metronome_docs.db
# Vercel production: DATABASE_URL is REQUIRED (Supabase pooled PostgreSQL)
# DATABASE_URL=postgresql://user:password@host:5432/dbname?pgbouncer=true

# ----- Gemini API -----
# Required when DRAFTING_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3.1-flash-lite

# ----- Drafting provider -----
# Use "mock" for development without live API calls
# Use "gemini" for the live demonstration
DRAFTING_PROVIDER=mock

# ----- Drafting generation settings -----
DRAFTING_TEMPERATURE=0.2
DRAFTING_MAX_OUTPUT_TOKENS=2048

# ----- Review workflow -----
DRAFTING_REQUIRE_HUMAN_REVIEW=true
DRAFTING_STORE_FAILED_OUTPUTS=true

# ----- Vercel -----
# VERCEL=1 is set automatically by the Vercel platform
# FLASK_SECRET_KEY= change in production
